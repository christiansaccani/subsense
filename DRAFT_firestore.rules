rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'name', 'cost', 'cycle', 'renewalDate', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.cost is number && data.cost >= 0 &&
             data.cycle in ['monthly', 'annual'] &&
             data.renewalDate is timestamp &&
             data.createdAt is timestamp;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])
      );
    }

    // 2. Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      isValidSubscription(incoming()) &&
                      isValidId(subscriptionId);
                      
      allow update: if isSignedIn() && 
                      existing().userId == request.auth.uid && 
                      incoming().userId == request.auth.uid &&
                      isValidSubscription(incoming()) && (
                        // Regular updates
                        incoming().diff(existing()).affectedKeys().hasAll([]) // ensures validation still runs
                      );
                      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
