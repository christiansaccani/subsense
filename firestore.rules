rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isAuthenticated() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'emailVerified', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() > 0 &&
             data.emailVerified is bool &&
             data.createdAt is timestamp &&
             (!data.keys().contains('firstName') || (data.firstName is string && data.firstName.size() <= 100)) &&
             (!data.keys().contains('lastName') || (data.lastName is string && data.lastName.size() <= 100)) &&
             (!data.keys().contains('googleLinked') || data.googleLinked is bool);
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'name', 'cost', 'cycle', 'renewalDate', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.cost is number && data.cost >= 0 &&
             data.cycle in ['monthly', 'annual'] &&
             data.renewalDate is timestamp &&
             data.createdAt is timestamp;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == userId; // Broadened for debugging
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // 2. Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      
      allow create: if request.auth != null && 
                      isEmailVerified() &&
                      request.resource.data.userId == request.auth.uid && 
                      isValidSubscription(request.resource.data) &&
                      isValidId(subscriptionId);
                      
      allow update: if request.auth != null && 
                      isEmailVerified() &&
                      resource.data.userId == request.auth.uid && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidSubscription(request.resource.data) && (
                        // Regular updates
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'cost', 'cycle', 'category', 'renewalDate', 'remindersEnabled', 'usageFrequency', 'usageTimeLabel', 'lastUsedAt', 'isLinked'])
                      );
                      
      allow delete: if request.auth != null && 
                      isEmailVerified() &&
                      resource.data.userId == request.auth.uid;
    }
  }
}
